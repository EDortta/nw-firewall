# auth-monitor v4 environment example
# Copy to .env and adjust values per host.

# Required security secrets
AUTH_MONITOR_MQTT_PASSWORD=change-me
AUTH_MONITOR_EVENT_HMAC=change-me-long-random-secret

# Signature policy (recommended: keep enabled)
AUTH_MONITOR_REQUIRE_SIGNATURE=1

# Optional: allow mosquitto_pub fallback (less secure: password may be visible in process list)
ALLOW_INSECURE_MOSQUITTO_PUB=0

# General paths
AUTH_MONITOR_CONFIG=/home/devops/auth-monitor/v4/config/config.json
BLOCKED_IPS_DB_PATH=/home/devops/auth-monitor/v4/db/blocked_ips.db
WHITELIST_PATH=/home/devops/auth-monitor/v4/db/whitelist.json
MQTT_LAST_TS_PATH=/home/devops/auth-monitor/v4/db/.mqtt_last_published_ts
AUTH_MONITOR_LOG_PATH=/var/log/nw-monitor.log

# Log sources
NGINX_ACCESS_LOG=/var/log/nginx/access.log
AUTH_LOG_PATH=/var/log/auth.log
LOG_TAIL_LINES=5500
AUTH_LOG_TAIL_LINES=5500

# Detection tuning
# Main rule: burst of 404 from same IP within window
HTTP_404_BURST_THRESHOLD=12
HTTP_404_WINDOW_SECONDS=120

# Secondary scan heuristics
BURST_BAD_STATUS_THRESHOLD=25
BURST_UNIQUE_PATH_THRESHOLD=15
AUTH_MIN_EVENTS_PER_IP=5

# MQTT overrides (optional)
# MQTT_TOPIC=auth-monitor/blocked-ips
# MQTT_DRY_RUN=0

# Identity overrides (optional)
# AUTH_MONITOR_CLIENT_NAME=
# AUTH_MONITOR_CLIENT_IP=
# AUTH_MONITOR_AGENT_NAME=
# AUTH_MONITOR_AGENT_IP=
# AUTH_MONITOR_SERVER_NAME=
# AUTH_MONITOR_SERVER_IP=

# Firewall behavior (optional)
# IPTABLES_CMD=/usr/sbin/iptables
# IP6TABLES_CMD=/usr/sbin/ip6tables
# IPTABLES_CHAIN=INPUT
# IPTABLES_TARGET=DROP
# IPTABLES_INSERT_TOP=1

# Lock file overrides (optional)
# MQTT_LISTENER_LOCK_FILE=/var/run/auth-monitor-mqtt-listener.lock
# IPTABLES_AGENT_LOCK_FILE=/var/run/auth-monitor-iptables-agent.lock
