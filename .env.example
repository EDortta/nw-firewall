# authmon v5 secrets — copy to /etc/authmon/env, chmod 600, chown root:root.
# Secrets live ONLY here. The config loader refuses inline secrets in config.json.

# MQTT broker password for this node's user
AUTHMON_MQTT_PASSWORD=change-me

# HMAC key signing every event on the grid (long random value, e.g. `openssl rand -base64 48`)
AUTHMON_EVENT_HMAC=change-me

# Optional: previous HMAC key, kept accepted during rotation. Remove after rollout.
#AUTHMON_EVENT_HMAC_PREVIOUS=

# Border API only (broker node)
#AUTHMON_API_KEY=change-me

# Optional overrides
#AUTHMON_CONFIG=/etc/authmon/config.json
#AUTHMON_API_HOST=127.0.0.1
#AUTHMON_API_PORT=8741
