[Unit]
Description=authmon v5 detector (log analysis -> outbox)

[Service]
Type=oneshot
EnvironmentFile=/etc/authmon/env
ExecStart=/usr/bin/python3 /opt/authmon/v5/detector/detect.py
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/authmon
ProtectHome=true
PrivateTmp=true
StandardOutput=append:/var/log/authmon/detector.log
StandardError=append:/var/log/authmon/detector.log
